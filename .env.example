# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Converso
APP_ENV=production
SECRET_KEY=replace-me-with-openssl-rand-hex-32

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── OpenAI (AI replies) ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo

# ── VAPI (voice calls) ────────────────────────────────────────────────────────
VAPI_API_KEY=your_vapi_key
VAPI_BASE_URL=https://api.vapi.ai

# ── Cal.com (self-hosted) ─────────────────────────────────────────────────────
# Base URL of your Cal.com instance, e.g. https://cal.yourdomain.com/api/v2
CALCOM_BASE_URL=https://cal.yourdomain.com/api/v2
# API key from Cal.com Settings → Developer → API Keys
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxx
# Webhook secret set in Cal.com Settings → Developer → Webhooks
CALCOM_WEBHOOK_SECRET=your_webhook_secret

# ── Internal (set automatically by docker-compose) ───────────────────────────
# DATABASE_URL=postgresql+asyncpg://converso:password@postgres:5432/converso
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/1
# CELERY_RESULT_BACKEND=redis://redis:6379/2
