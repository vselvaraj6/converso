{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "cronSchedule": ""
  },
  "services": [
    {
      "name": "web",
      "source": "Dockerfile",
      "builder": "DOCKERFILE",
      "buildCommand": "",
      "startCommand": "./start.sh"
    }
  ]
}